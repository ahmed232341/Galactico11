---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Galactico11" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#090a0f" />
    <meta name="description" content="Build football's ultimate eleven in Galactico11." />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
